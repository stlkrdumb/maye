# ===========================================
# Maye — Environment Variables
# ===========================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# ---- Blockchain / RPC ----
# Alchemy API key for Base Sepolia (or use public RPC)
ALCHEMY_API_KEY=your_alchemy_api_key

# ---- Deployment ----
# Private key of the deployer wallet (DO NOT commit real keys!)
DEPLOYER_PRIVATE_KEY=0xyour_private_key_here
NEXT_PUBLIC_BORROWER_REGISTRY_ADDRESS=0xDC001b38ee9cFbf037c00e59b6FC8F1B2CE922FE

# ---- Verification ----
# Basescan API key for contract verification
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key

# ---- Post-Deployment Setup (optional) ----
# Address to register as a test borrower
TEST_BORROWER=0xyour_test_address_here

# ---- Reclaim Protocol (ZKP) ----
# Get these at: https://dev.reclaimprotocol.org
NEXT_PUBLIC_RECLAIM_APP_ID=your_reclaim_app_id
RECLAIM_APP_SECRET=your_reclaim_app_secret
NEXT_PUBLIC_RECLAIM_PROVIDER_ID=your_reclaim_provider_id # e.g. Stripe, Chase, or custom

# ---- Frontend (Next.js) ----
# These may be needed for wallet integration
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}
